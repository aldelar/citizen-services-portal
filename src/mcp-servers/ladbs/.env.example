# MCP Server Configuration
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000

# For testing deployed Azure service, use:
# MCP_SERVER_HOST=aldelar-csp-mcp-ladbs.gentlewave-1b3fce06.northcentralus.azurecontainerapps.io
# MCP_SERVER_PORT=443

# Azure Configuration (if needed)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# LADBS Service Configuration (example)
# LADBS_API_ENDPOINT=https://api.ladbs.example.com
# LADBS_API_KEY=your-api-key

# CosmosDB Configuration (for database persistence)
# COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
# COSMOS_DATABASE=ladbs

# Azure AI Search Configuration (for knowledge base queries)
# AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
# AZURE_SEARCH_INDEX_NAME=ladbs-kb
# AZURE_SEARCH_SEMANTIC_CONFIG=ladbs-semantic-config
