# MCP Server Configuration
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8000

# For testing deployed Azure service, use:
# MCP_SERVER_HOST=aldelar-csp-mcp-csp.gentlewave-1b3fce06.northcentralus.azurecontainerapps.io
# MCP_SERVER_PORT=443

# Azure Configuration (if needed)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Cosmos DB Configuration (optional - uses mock data if not set)
# COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/

# Reporting database (step completions for analytics)
# COSMOS_DATABASE_REPORTING=reporting
# COSMOS_CONTAINER_STEP_COMPLETIONS=step_completions

# Citizen Services database (projects/plans)
# COSMOS_DATABASE=csp
# COSMOS_CONTAINER_PROJECTS=projects
