# Development mode (enables hot-reload)
DEBUG=true

# Authentication (mock for local development)
USE_MOCK_AUTH=true
MOCK_USER_ID=local-dev-user
MOCK_USER_EMAIL=dev@example.com

# Server configuration
NICEGUI_PORT=8080
NICEGUI_HOST=0.0.0.0

# Backend services
CSP_AGENT_URL=http://localhost:8088
CSP_AGENT_USE_AUTH=false

# CosmosDB Configuration (optional - uses in-memory storage if not set)
# Get these values from Azure Portal or 'azd env get-values'
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DATABASE=csp
